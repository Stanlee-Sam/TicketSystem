generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STAFF
  IT_ADMIN
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketCategory {
  HARDWARE
  SOFTWARE
  NETWORK
  PRINTER
  EMAIL
  OTHER
}

model User {
  id             String   @id @default(uuid())
  fullName       String
  email          String   @unique
  passwordHash   String
  role           UserRole @default(STAFF)
  mustChangePass Boolean  @default(true)
  isActive       Boolean  @default(true)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  submittedTickets Ticket[] @relation("SubmittedTickets")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
}

model Department {
  id      String   @id @default(uuid())
  name    String   @unique
  users   User[]
  tickets Ticket[]
}

model Ticket {
  id          String @id @default(uuid())
  title       String
  description String

  priority TicketPriority @default(MEDIUM)
  category TicketCategory @default(OTHER)
  status   TicketStatus   @default(OPEN)

  submitterId String
  submitter   User   @relation("SubmittedTickets", fields: [submitterId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  attachments Attachment[]

  resolutionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([departmentId])
  @@index([submitterId])
}

model Attachment {
  id String @id @default(uuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  fileUrl String

  createdAt DateTime @default(now())
}

